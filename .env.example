# Server Configuration
NODE_ENV=production
PORT=5000
BASE_URL=http://localhost:5000

# Database
MONGODB_URI=mongodb://mongodb:27017/taskflow

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
COOKIE_EXPIRE=7

# Email Settings
DISABLE_EMAIL=false

# Email Configuration (SMTP)
EMAIL_SERVICE= # Opsional: 'gmail', 'sendgrid', dll (Jika diisi, EMAIL_HOST dan EMAIL_PORT akan diabaikan)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false # Set to true untuk port 465 (SSL), false untuk port 587 (TLS/STARTTLS)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=TaskFlow <noreply@taskflow.com>

# Cloudinary (File Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=your_cloudinary_preset

# Session
SESSION_SECRET=your_session_secret_key_here

# Frontend URL (For CORS and redirect configurations)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes in ms
RATE_LIMIT_MAX=100

# OAuth Credentials (Google, GitHub, Zoom)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/meetings/callback/google

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_REDIRECT_URI=http://localhost:5000/api/meetings/callback/zoom

# Security Tokens
SECRET_TOKEN=your_secure_random_token_here

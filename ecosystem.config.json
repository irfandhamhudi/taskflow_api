{
  "apps": [
    {
      "name": "taskflow-api",
      "script": "server.js",
      "instances": "max",
      "exec_mode": "cluster",
      "autorestart": true,
      "watch": false,
      "max_memory_restart": "1G",
      "combine_logs": true,
      "out_file": "./logs/pm2-out.log",
      "error_file": "./logs/pm2-error.log",
      "env": {
        "NODE_ENV": "development"
      },
      "env_production": {
        "NODE_ENV": "production"
      }
    }
  ]
}
